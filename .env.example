# AutoPlanner Coder v3 — Environment Configuration
# Copy this file to .env and fill in your settings.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Auto-detection order: ollama → google → openai → anthropic
# Force a specific one:
PLANNER_PROVIDER=ollama

# ── Ollama (local, no API key needed) ────────────────────────────────────────
# Uses llama3.2:1b by default on your local Ollama server.
OLLAMA_BASE_URL=http://localhost:11434
PLANNER_MODEL=llama3.2:1b

# ── Google Gemini ─────────────────────────────────────────────────────────────
# PLANNER_PROVIDER=google
# GOOGLE_API_KEY=your-google-api-key-here
# PLANNER_MODEL=gemini-2.0-flash

# ── OpenAI ────────────────────────────────────────────────────────────────────
# PLANNER_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here
# PLANNER_MODEL=gpt-4o

# ── Anthropic ─────────────────────────────────────────────────────────────────
# PLANNER_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# PLANNER_MODEL=claude-3-5-sonnet-20241022
